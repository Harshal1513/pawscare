# ============================================================
# Paws Care and Heal Pet Clinic — Environment Variables
# Copy this to .env.local and fill in your values
# NEVER commit .env.local to git!
# ============================================================

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Cron job security secret (any random string)
CRON_SECRET=your-random-secret-here

# Optional: WhatsApp Cloud API (uncomment when ready)
# WA_PHONE_NUMBER_ID=your_wa_phone_number_id
# WA_ACCESS_TOKEN=your_wa_access_token
